SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco local (Postgres fora do Docker / host)
DB_NAME=mediclaw
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Dev Container (.devcontainer): abra a pasta django-api como raiz do workspace.
# Dentro do Compose, o Django deve apontar para o serviço (DNS), não para container_name:
#   DB_HOST=postgres
#   DB_PORT=5432
# Do host (psql, DBeaver, etc.) contra o Postgres publicado pelo compose:
#   localhost:25432  (container_name medi_postgres; nome fixo pode colidir se outro projeto usar o mesmo)

ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=1

CORS_ALLOWED_ORIGINS=http://localhost:3000

# AI Engine — defina apenas o provedor que for usar
LLM_PROVIDER=openai        # openai | gemini
OPENAI_API_KEY=sk-...
CHAT_MODEL=gpt-4o-mini     # ou gemini-1.5-flash para Gemini

# Google Gemini (alternativa ao OpenAI)
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=AIza...
# CHAT_MODEL=gemini-1.5-flash

HISTORY_WINDOW=6
MAX_TOKENS_PER_RESPONSE=800
DATA_CAPTURE_LLM=true

# RAG
CHROMA_PERSIST_DIR=./chroma_data
ANONYMIZED_TELEMETRY=False
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5
RAG_MIN_SCORE=0.40
