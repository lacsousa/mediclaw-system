{
  "name": "Mediclaw Django API",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainer-community/devcontainer-features/astral.sh-uv:1": {}
  },
  "containerEnv": {
    "UV_LINK_MODE": "copy"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.isort",
        "ms-python.pylint",
        "ms-python.debugpy",
        "ms-python.vscode-python-envs"
      ]
    }
  },
  "forwardPorts": [8000, 25432],
  "postCreateCommand": "([ -f .env ] || cp .env.example .env) && python -m pip install -U pip && pip install -r requirements.txt && python manage.py migrate --noinput"
}
